# prd_skill LLM provider 配置示例

# 可选值：
# - stub
# - openai_compatible
PRD_SKILL_LLM_PROVIDER=stub

# 当前仅支持 openai_compatible
PRD_SKILL_LLM_API_STYLE=openai_compatible

# openai_compatible 模式下的服务根地址
# 例如：https://api.openai.com/v1
PRD_SKILL_LLM_BASE_URL=https://your-provider.example/v1

# openai_compatible 模式下的 API Key
# 不要提交真实密钥
PRD_SKILL_LLM_API_KEY=your_api_key_here

# openai_compatible 模式下的模型名
PRD_SKILL_LLM_MODEL=your_model_name_here

# 结构化任务使用的 temperature
# 适用于 facts 抽取与下一问生成
PRD_SKILL_LLM_TEMPERATURE_JSON=0.1

# 文本任务使用的 temperature
# 适用于 PRD markdown 生成
PRD_SKILL_LLM_TEMPERATURE_TEXT=0.3

# HTTP 请求超时时间，单位秒
PRD_SKILL_LLM_TIMEOUT_SECONDS=30

# 是否启用 response_format={"type":"json_object"}
# 支持值：true/false、1/0、yes/no、on/off
PRD_SKILL_LLM_RESPONSE_FORMAT_ENABLED=true

# 如果希望本地开发直接走 stub，可保持上面的 PROVIDER=stub
# 如果要切到真实 LLM，请至少修改：
# - PRD_SKILL_LLM_PROVIDER=openai_compatible
# - PRD_SKILL_LLM_BASE_URL
# - PRD_SKILL_LLM_API_KEY
# - PRD_SKILL_LLM_MODEL
